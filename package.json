{
  "name": "githassistant",
  "version": "1.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "job:squash": "tsx src/jobs/squash.ts",
    "job:summary": "tsx src/jobs/dailySummary.ts",
    "cf:deploy": "wrangler deploy",
    "cf:dev": "wrangler dev",
    "cf:register-webhook": "tsx scripts/register-webhook.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@octokit/rest": "^22.0.1",
    "dotenv": "^17.4.2",
    "node-cron": "^4.2.1",
    "openai": "^6.36.0",
    "pino": "^10.3.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "nock": "^14.0.15",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.88.0"
  }
}
