name = "githassistant"
main = "src/platforms/cloudflare/worker.ts"
compatibility_date = "2024-09-23"
compatibility_flags = ["nodejs_compat"]

[[kv_namespaces]]
binding = "GITHASSISTANT_KV"
id = "REPLACE_WITH_KV_NAMESPACE_ID"

[[d1_databases]]
binding = "GITHASSISTANT_DB"
database_name = "githassistant-db"
database_id = "REPLACE_WITH_D1_DATABASE_ID"

[triggers]
# 07:00 + 08:00 UTC = daily summary at 08:00 Europe/Lisbon (DST-guarded in code); 0 * * * * = hourly meeting scan
crons = ["0 7 * * *", "0 8 * * *", "0 * * * *"]

[[queues.producers]]
queue = "githassistant-queue"
binding = "BOT_QUEUE"

[[queues.consumers]]
queue = "githassistant-queue"
max_batch_size = 1
max_batch_timeout = 0
max_retries = 2

[ai]
binding = "AI"

[vars]
# --- Project (replace with your values) ---
TELEGRAM_GROUP_ID = "REPLACE_WITH_TELEGRAM_GROUP_ID"
TELEGRAM_ALLOWED_USERS = ""
GITHUB_OWNER = "REPLACE_WITH_GITHUB_OWNER"
GITHUB_REPO = "REPLACE_WITH_GITHUB_REPO"
GITHUB_DEFAULT_BRANCH = "main"

# --- AI ---
# AI_PROVIDER is auto-detected: anthropic → openai → cloudflare (CF Workers AI)
# Uncomment to override: AI_PROVIDER = "anthropic"
ANTHROPIC_MODEL = "claude-sonnet-4-5"
OPENAI_MODEL = "gpt-5.3"
CF_AI_MODEL = "@cf/meta/llama-3.3-70b-instruct-fp8-fast"

# --- Notes ---
DOCS_PATH = "docs"
MEETING_NOTES_FOLDER = "meetings"
NOTE_ALLOWED_EXTENSIONS = "md,txt"
NOTE_EXCLUDED_PATHS = ""
NOTE_SHORTCUTS = ""

# --- Scheduler ---
NIGHTLY_CRON = "0 2 * * *"
TIMEZONE = "UTC"

# --- Behaviour ---
SUMMARY_MAX_DAYS = "7"
SUMMARY_LANGUAGE = "en"
LOG_LEVEL = "info"
RATE_LIMIT_PER_MIN = "10"
AI_CALL_DELAY_MS = "10000"
DAILY_SUMMARY_MAX_COMMITS = "25"
# AI_INPUT_TRUNCATE_CHARS = "80000"

# --- Auto-create GitHub issues from meeting action items (optional) ---
# Positional parallel lists: full name in transcript -> GitHub login
# AUTO_CREATED_ISSUE_FOR_OWNER_NAMES = "John First,Joanna Second"
# AUTO_CREATED_ISSUE_FOR_GITHUBNAMES = "john-gh,joanna-gh"

[observability.logs]
enabled = true
invocation_logs = true
