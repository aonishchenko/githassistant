# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_ID=
TELEGRAM_ALLOWED_USERS=alice,bob

# === GitHub ===
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_DEFAULT_BRANCH=main

# === Docs ===
DOCS_PATH=docs
MEETING_NOTES_FOLDER=meetings
NOTE_EXCLUDED_PATHS=
NOTE_SHORTCUTS=
NOTE_ALLOWED_EXTENSIONS=md,txt

# === AI ===
# Set AI_PROVIDER explicitly, or omit to auto-detect from whichever key is set.
# Priority: anthropic (if key set) → openai (if key set) → cloudflare (CF Workers AI, no key needed)
# Supported values: anthropic, openai, cloudflare
#AI_PROVIDER=anthropic
#AI_PROVIDER=openai
#AI_PROVIDER=cloudflare
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.3
CF_AI_MODEL=@cf/moonshotai/kimi-k2.6

# === Scheduler ===
NIGHTLY_CRON=0 2 * * *
TIMEZONE=UTC

# === Behaviour ===
SUMMARY_MAX_DAYS=7
SUMMARY_LANGUAGE=en
LOG_LEVEL=info
RATE_LIMIT_PER_MIN=10
# AI_INPUT_TRUNCATE_CHARS=80000
AI_CALL_DELAY_MS=10000

# === Cloudflare Workers (only needed for CF deployment) ===
# CF_WORKER_URL=https://githassistant.<subdomain>.workers.dev
